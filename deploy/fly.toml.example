# Claw on Fly.io
# Copy to deploy/fly.toml and adjust as needed.

app = 'claw-agent'
primary_region = 'iad'

[build]
  dockerfile = 'deploy/Dockerfile'

[http_service]
  internal_port = 6688
  force_https = true
  auto_stop_machines = 'stop'
  auto_start_machines = true
  min_machines_running = 0
  processes = ['app']

[[vm]]
  memory = '1gb'
  cpu_kind = 'shared'
  cpus = 1

[env]
  CLAW_PERMISSION = 'ask'
